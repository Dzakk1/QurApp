<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp">

        <!-- Icon Background -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIcon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            app:cardBackgroundColor="#FFF3E8"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivDoaItemIcon"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/book_ribbon_24px"
                android:tint="@color/orangePrimary" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Nama Doa -->
        <TextView
            android:id="@+id/tvNamaDoa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:fontFamily="@font/poppinsbold"
            android:text="Doa Sebelum Tidur"
            android:textColor="@color/orangePrimary"
            android:textSize="16sp"
            app:layout_constraintBottom_toTopOf="@id/tvGroupDoa"
            app:layout_constraintEnd_toStartOf="@id/ivDetailIcon"
            app:layout_constraintStart_toEndOf="@id/cardIcon"
            app:layout_constraintTop_toTopOf="@id/cardIcon"
            app:layout_constraintVertical_chainStyle="packed"/>

        <!-- Kategori -->
        <TextView
            android:id="@+id/tvGroupDoa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:fontFamily="@font/poppins_medium"
            android:text="Doa Harian"
            android:textColor="#8A8A8A"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/ivDetailIcon"
            app:layout_constraintStart_toStartOf="@id/tvNamaDoa"
            app:layout_constraintTop_toBottomOf="@id/tvNamaDoa"/>

        <!-- Arrow -->
        <ImageView
            android:id="@+id/ivDetailIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/round_chevron_right_24"
            android:tint="@color/orangePrimary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>